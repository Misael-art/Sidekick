<Window x:Class="Ajudante.App.Overlays.SnipWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Snip Capture"
        AllowsTransparency="True"
        WindowStyle="None"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Cursor="Cross"
        Background="Transparent"
        Loaded="Window_Loaded"
        KeyDown="Window_KeyDown"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        MouseMove="Window_MouseMove"
        MouseLeftButtonUp="Window_MouseLeftButtonUp"
        MouseRightButtonDown="Window_MouseRightButtonDown">

    <Canvas x:Name="OverlayCanvas" ClipToBounds="True">

        <!-- Semi-transparent dark overlay covering the entire screen.
             We use four rectangles around the selection to create the "cutout" effect. -->

        <!-- Full dark backdrop (visible before dragging starts) -->
        <Rectangle x:Name="Backdrop"
                   Fill="#88000000"
                   IsHitTestVisible="False" />

        <!-- Four darkening rectangles that form the frame around the selection -->
        <Rectangle x:Name="TopShade"    Fill="#88000000" IsHitTestVisible="False" />
        <Rectangle x:Name="BottomShade" Fill="#88000000" IsHitTestVisible="False" />
        <Rectangle x:Name="LeftShade"   Fill="#88000000" IsHitTestVisible="False" />
        <Rectangle x:Name="RightShade"  Fill="#88000000" IsHitTestVisible="False" />

        <!-- Selection rectangle with dashed border -->
        <Border x:Name="SelectionBorder"
                BorderThickness="1.5"
                IsHitTestVisible="False"
                Visibility="Collapsed">
            <Border.BorderBrush>
                <SolidColorBrush Color="#FFFFFFFF" />
            </Border.BorderBrush>
        </Border>

        <!-- Inner dashed rectangle for a polished snipping look -->
        <Rectangle x:Name="SelectionDash"
                   Stroke="#CCFFFFFF"
                   StrokeThickness="1"
                   StrokeDashArray="4 2"
                   Fill="Transparent"
                   IsHitTestVisible="False"
                   Visibility="Collapsed" />

        <!-- Crosshair lines (full screen, follow cursor before drag) -->
        <Line x:Name="CrosshairH"
              Stroke="#44FFFFFF"
              StrokeThickness="1"
              IsHitTestVisible="False"
              Visibility="Collapsed" />
        <Line x:Name="CrosshairV"
              Stroke="#44FFFFFF"
              StrokeThickness="1"
              IsHitTestVisible="False"
              Visibility="Collapsed" />

        <!-- Dimension label near the selection -->
        <Border x:Name="DimensionPanel"
                Background="#DD181825"
                BorderBrush="#FF6C7086"
                BorderThickness="1"
                CornerRadius="4"
                Padding="8,4"
                Visibility="Collapsed"
                IsHitTestVisible="False">
            <TextBlock x:Name="DimensionText"
                       FontSize="12"
                       FontFamily="Consolas"
                       Foreground="#FFCDD6F4" />
        </Border>

        <!-- Hint text shown at top-center before dragging -->
        <Border x:Name="HintPanel"
                Background="#DD181825"
                BorderBrush="#FF6C7086"
                BorderThickness="1"
                CornerRadius="6"
                Padding="16,8"
                IsHitTestVisible="False">
            <TextBlock Text="Click and drag to select a region  |  Esc or Right-click to cancel"
                       FontSize="12"
                       Foreground="#FFA6ADC8" />
        </Border>

    </Canvas>
</Window>
