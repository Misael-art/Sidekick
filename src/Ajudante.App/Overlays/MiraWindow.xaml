<Window x:Class="Ajudante.App.Overlays.MiraWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mira Inspector"
        AllowsTransparency="True"
        WindowStyle="None"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Cursor="Cross"
        Loaded="Window_Loaded"
        KeyDown="Window_KeyDown"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Canvas x:Name="OverlayCanvas">

        <!-- Highlight rectangle drawn over the inspected element -->
        <Border x:Name="HighlightBorder"
                BorderBrush="#FF4CAF50"
                BorderThickness="2"
                Background="#184CAF50"
                CornerRadius="2"
                Visibility="Collapsed"
                IsHitTestVisible="False" />

        <!-- Floating info tooltip near the cursor -->
        <Border x:Name="InfoPanel"
                Background="#F0181825"
                BorderBrush="#FF6C7086"
                BorderThickness="1"
                CornerRadius="6"
                Padding="10,8"
                Visibility="Collapsed"
                IsHitTestVisible="False">
            <Border.Effect>
                <DropShadowEffect Color="#000000"
                                  BlurRadius="12"
                                  ShadowDepth="4"
                                  Opacity="0.5" />
            </Border.Effect>
            <StackPanel>
                <!-- Header: ControlType -->
                <TextBlock x:Name="ControlTypeText"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="#FF89B4FA"
                           Margin="0,0,0,4" />

                <!-- Name -->
                <StackPanel Orientation="Horizontal" Margin="0,1">
                    <TextBlock Text="Name: "
                               FontSize="11"
                               Foreground="#FF6C7086" />
                    <TextBlock x:Name="NameText"
                               FontSize="11"
                               Foreground="#FFCDD6F4"
                               MaxWidth="320"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>

                <!-- ClassName -->
                <StackPanel Orientation="Horizontal" Margin="0,1">
                    <TextBlock Text="Class: "
                               FontSize="11"
                               Foreground="#FF6C7086" />
                    <TextBlock x:Name="ClassNameText"
                               FontSize="11"
                               Foreground="#FFCDD6F4"
                               MaxWidth="320"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>

                <!-- AutomationId -->
                <StackPanel Orientation="Horizontal" Margin="0,1">
                    <TextBlock Text="AutomationId: "
                               FontSize="11"
                               Foreground="#FF6C7086" />
                    <TextBlock x:Name="AutomationIdText"
                               FontSize="11"
                               Foreground="#FFCDD6F4"
                               MaxWidth="320"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>

                <!-- BoundingRect -->
                <StackPanel Orientation="Horizontal" Margin="0,1">
                    <TextBlock Text="Bounds: "
                               FontSize="11"
                               Foreground="#FF6C7086" />
                    <TextBlock x:Name="BoundsText"
                               FontSize="11"
                               Foreground="#FFA6ADC8" />
                </StackPanel>

                <!-- Hint at bottom -->
                <TextBlock Text="Click to capture  |  Esc to cancel"
                           FontSize="10"
                           Foreground="#FF585B70"
                           Margin="0,6,0,0" />
            </StackPanel>
        </Border>

    </Canvas>
</Window>
