<Window x:Class="Ajudante.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        mc:Ignorable="d"
        Icon="icon.ico"
        Title="Sidekick - Visual Automation"
        Height="800" Width="1280"
        MinHeight="600" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2E"
        Loaded="Window_Loaded"
        Closing="Window_Closing">

    <!-- Dark title bar via WindowChrome for a frameless modern look -->
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0"
                      ResizeBorderThickness="6"
                      GlassFrameThickness="0"
                      CornerRadius="0" />
    </WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <!-- Custom title bar -->
            <RowDefinition Height="32" />
            <!-- WebView2 content -->
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Custom title bar for dark theme -->
        <Grid Grid.Row="0" Background="#181825" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- App title -->
            <TextBlock Grid.Column="0"
                       Text="Sidekick"
                       Foreground="#CDD6F4"
                       FontSize="13"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"
                       Margin="12,0,0,0" />

            <!-- Window control buttons -->
            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <Button Content="&#xE949;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                        Click="MinimizeButton_Click" Style="{StaticResource TitleBarButton}" />
                <Button x:Name="MaximizeButton" Content="&#xE739;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                        Click="MaximizeButton_Click" Style="{StaticResource TitleBarButton}" />
                <Button Content="&#xE106;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                        Click="CloseButton_Click" Style="{StaticResource TitleBarCloseButton}" />
            </StackPanel>
        </Grid>

        <!-- WebView2 filling the rest of the window -->
        <wv2:WebView2 x:Name="WebView"
                      Grid.Row="1"
                      DefaultBackgroundColor="#1E1E2E" />
    </Grid>
</Window>
