{
  "id": "recipe-whatsapp-status-assistant",
  "name": "Recipe - WhatsApp Status Assistant (Draft Safe)",
  "version": 5,
  "variables": [
    {
      "name": "whatsappOwnerPhone",
      "type": "String",
      "default": "5511959766061"
    },
    {
      "name": "whatsappOwnerPhoneSearch",
      "type": "String",
      "default": "11959766061"
    },
    {
      "name": "whatsappOwnerContactName",
      "type": "String",
      "default": "Papai Oliveira Novo"
    },
    {
      "name": "whatsappWebUrl",
      "type": "String",
      "default": "https://web.whatsapp.com/"
    },
    {
      "name": "whatsappWindowTitle",
      "type": "String",
      "default": "WhatsApp"
    },
    {
      "name": "whatsappProcessName",
      "type": "String",
      "default": "msedge"
    },
    {
      "name": "whatsappProcessPath",
      "type": "String",
      "default": ""
    },
    {
      "name": "whatsappSearchPlaceholder",
      "type": "String",
      "default": "Pesquisar ou começar uma nova conversa"
    },
    {
      "name": "whatsappComposerHint",
      "type": "String",
      "default": "Digite uma mensagem"
    },
    {
      "name": "whatsappChatAreaHint",
      "type": "String",
      "default": "Clique neste aviso"
    },
    {
      "name": "allowedCommands",
      "type": "String",
      "default": "ipconfig,whoami,hostname,systeminfo,ver"
    },
    {
      "name": "runnableFlowAllowlist",
      "type": "String",
      "default": "portfolio-*"
    },
    {
      "name": "screenshotFolder",
      "type": "String",
      "default": "%USERPROFILE%\\Pictures\\Sidekick"
    },
    {
      "name": "lastChatMessage",
      "type": "String",
      "default": "4"
    },
    {
      "name": "whatsappResponseMessage",
      "type": "String",
      "default": ""
    }
  ],
  "nodes": [
    {
      "id": "start",
      "typeId": "trigger.manualStart",
      "position": { "x": 80, "y": 120 },
      "properties": {}
    },
    {
      "id": "focus-existing-whatsapp",
      "typeId": "action.windowControl",
      "position": { "x": 320, "y": 120 },
      "properties": {
        "windowTitle": "{{whatsappWindowTitle}}",
        "windowTitleMatch": "contains",
        "processName": "{{whatsappProcessName}}",
        "processPath": "{{whatsappProcessPath}}",
        "automationId": "",
        "elementName": "",
        "elementNameMatch": "contains",
        "controlType": "Window",
        "timeoutMs": 3000,
        "operation": "bringToFront"
      }
    },
    {
      "id": "open-whatsapp",
      "typeId": "action.browserOpenUrl",
      "position": { "x": 320, "y": 300 },
      "properties": {
        "url": "{{whatsappWebUrl}}"
      }
    },
    {
      "id": "wait-login",
      "typeId": "action.browserWaitElement",
      "position": { "x": 600, "y": 120 },
      "properties": {
        "windowTitle": "{{whatsappWindowTitle}}",
        "windowTitleMatch": "contains",
        "processName": "{{whatsappProcessName}}",
        "processPath": "{{whatsappProcessPath}}",
        "automationId": "",
        "elementName": "{{whatsappSearchPlaceholder}}",
        "elementNameMatch": "contains",
        "controlType": "Edit",
        "timeoutMs": 15000,
        "storeInVariable": "whatsappLoggedIn"
      }
    },
    {
      "id": "log-login-required",
      "typeId": "action.logMessage",
      "position": { "x": 600, "y": 300 },
      "properties": {
        "message": "WhatsApp Web ainda nao esta logado ou a busca nao apareceu. Escaneie o QR code no Edge; o Sidekick vai aguardar antes de continuar.",
        "level": "warning"
      }
    },
    {
      "id": "wait-login-after-qr",
      "typeId": "action.browserWaitElement",
      "position": { "x": 880, "y": 300 },
      "properties": {
        "windowTitle": "{{whatsappWindowTitle}}",
        "windowTitleMatch": "contains",
        "processName": "{{whatsappProcessName}}",
        "processPath": "{{whatsappProcessPath}}",
        "automationId": "",
        "elementName": "{{whatsappSearchPlaceholder}}",
        "elementNameMatch": "contains",
        "controlType": "Edit",
        "timeoutMs": 300000,
        "storeInVariable": "whatsappLoggedIn"
      }
    },
    {
      "id": "log-login-timeout",
      "typeId": "action.logMessage",
      "position": { "x": 1160, "y": 300 },
      "properties": {
        "message": "Tempo de login do WhatsApp esgotado. Abra https://web.whatsapp.com/ no Edge, confirme o QR code e execute o fluxo novamente.",
        "level": "error"
      }
    },
    {
      "id": "type-owner-phone",
      "typeId": "action.browserType",
      "position": { "x": 880, "y": 120 },
      "properties": {
        "windowTitle": "{{whatsappWindowTitle}}",
        "windowTitleMatch": "contains",
        "processName": "{{whatsappProcessName}}",
        "processPath": "{{whatsappProcessPath}}",
        "automationId": "",
        "elementName": "{{whatsappSearchPlaceholder}}",
        "elementNameMatch": "contains",
        "controlType": "Edit",
        "text": "{{whatsappOwnerPhoneSearch}}",
        "clearExisting": true,
        "timeoutMs": 15000
      }
    },
    {
      "id": "delay-search-results",
      "typeId": "logic.delay",
      "position": { "x": 1160, "y": 120 },
      "properties": {
        "milliseconds": 1000
      }
    },
    {
      "id": "select-first-result",
      "typeId": "action.keyboardPress",
      "position": { "x": 1440, "y": 120 },
      "properties": {
        "key": "Down",
        "modifiers": "None"
      }
    },
    {
      "id": "delay-after-result-selection",
      "typeId": "logic.delay",
      "position": { "x": 1580, "y": 120 },
      "properties": {
        "milliseconds": 250
      }
    },
    {
      "id": "open-selected-chat",
      "typeId": "action.keyboardPress",
      "position": { "x": 1720, "y": 120 },
      "properties": {
        "key": "Return",
        "modifiers": "None"
      }
    },
    {
      "id": "wait-composer",
      "typeId": "action.browserWaitElement",
      "position": { "x": 2000, "y": 120 },
      "properties": {
        "windowTitle": "{{whatsappWindowTitle}}",
        "windowTitleMatch": "contains",
        "processName": "{{whatsappProcessName}}",
        "processPath": "{{whatsappProcessPath}}",
        "automationId": "",
        "elementName": "{{whatsappComposerHint}}",
        "elementNameMatch": "contains",
        "controlType": "Edit",
        "timeoutMs": 12000,
        "storeInVariable": "whatsappComposerReady"
      }
    },
    {
      "id": "click-contact-result",
      "typeId": "action.desktopClickElement",
      "position": { "x": 2000, "y": 300 },
      "properties": {
        "windowTitle": "{{whatsappWindowTitle}}",
        "windowTitleMatch": "contains",
        "processName": "{{whatsappProcessName}}",
        "processPath": "{{whatsappProcessPath}}",
        "automationId": "",
        "elementName": "{{whatsappOwnerContactName}}",
        "elementNameMatch": "contains",
        "controlType": "Text",
        "timeoutMs": 5000,
        "clickType": "single",
        "useRelativeFallback": false,
        "useScaledFallback": false,
        "useAbsoluteFallback": false,
        "restoreWindowBeforeFallback": true,
        "fallbackAnchorAutomationId": "",
        "fallbackAnchorElementName": "{{whatsappSearchPlaceholder}}",
        "fallbackAnchorElementNameMatch": "contains",
        "fallbackAnchorControlType": "Edit",
        "fallbackAnchorOffsetX": 170,
        "fallbackAnchorOffsetY": 145,
        "relativeX": 604,
        "relativeY": 383,
        "absoluteX": 553,
        "absoluteY": 401
      }
    },
    {
      "id": "wait-composer-after-click",
      "typeId": "action.browserWaitElement",
      "position": { "x": 2000, "y": 300 },
      "properties": {
        "windowTitle": "{{whatsappWindowTitle}}",
        "windowTitleMatch": "contains",
        "processName": "{{whatsappProcessName}}",
        "processPath": "{{whatsappProcessPath}}",
        "automationId": "",
        "elementName": "{{whatsappComposerHint}}",
        "elementNameMatch": "contains",
        "controlType": "Edit",
        "timeoutMs": 12000,
        "storeInVariable": "whatsappComposerReady"
      }
    },
    {
      "id": "log-contact-not-found",
      "typeId": "action.logMessage",
      "position": { "x": 2280, "y": 300 },
      "properties": {
        "message": "Nao consegui abrir o chat do proprio usuario. Confira o campo whatsappOwnerPhoneSearch ou ajuste whatsappOwnerContactName no fluxo.",
        "level": "error"
      }
    },
    {
      "id": "log-search-field-not-found",
      "typeId": "action.logMessage",
      "position": { "x": 1160, "y": 420 },
      "properties": {
        "message": "Nao consegui focar o campo de busca do WhatsApp. Confira se o WhatsApp Web esta logado e se o placeholder de busca em PT-BR continua correto.",
        "level": "error"
      }
    },
    {
      "id": "list-flows-start",
      "typeId": "action.listRunnableFlows",
      "position": { "x": 2000, "y": 120 },
      "properties": {
        "allowedFlowIds": "{{runnableFlowAllowlist}}",
        "includeHighRisk": true,
        "startNumber": 10,
        "storeMenuInVariable": "runnableFlowsMenu",
        "storeCatalogInVariable": "runnableFlowsCatalog"
      }
    },
    {
      "id": "compose-menu",
      "typeId": "logic.textTemplate",
      "position": { "x": 2280, "y": 120 },
      "properties": {
        "template": "Ola, eu sou o Sidekick local. Escolha uma opcao:\\n1 - Enviar print da tela\\n2 <comando> - Executar comando permitido\\n3 - Informacoes do sistema\\n4 - Atualizar lista de flows do portfolio\\n{{runnableFlowsMenu}}\\n0 - Desarmar/parar pelo Sidekick\\n\\nComandos permitidos: {{allowedCommands}}",
        "storeInVariable": "whatsappResponseMessage"
      }
    },
    {
      "id": "type-menu",
      "typeId": "action.browserType",
      "position": { "x": 2560, "y": 120 },
      "properties": {
        "windowTitle": "{{whatsappWindowTitle}}",
        "windowTitleMatch": "contains",
        "processName": "{{whatsappProcessName}}",
        "processPath": "{{whatsappProcessPath}}",
        "automationId": "",
        "elementName": "{{whatsappComposerHint}}",
        "elementNameMatch": "contains",
        "controlType": "Edit",
        "text": "{{whatsappResponseMessage}}",
        "clearExisting": false,
        "timeoutMs": 15000
      }
    },
    {
      "id": "send-menu",
      "typeId": "action.keyboardPress",
      "position": { "x": 2840, "y": 120 },
      "properties": {
        "key": "Return",
        "modifiers": "None"
      }
    },
    {
      "id": "watch-message",
      "typeId": "trigger.desktopElementTextChanged",
      "position": { "x": 80, "y": 620 },
      "properties": {
        "windowTitle": "{{whatsappWindowTitle}}",
        "windowTitleMatch": "contains",
        "processName": "{{whatsappProcessName}}",
        "processPath": "{{whatsappProcessPath}}",
        "automationId": "",
        "elementName": "{{whatsappChatAreaHint}}",
        "elementNameMatch": "contains",
        "controlType": "Group",
        "timeoutMs": 1000,
        "intervalMs": 2500,
        "cooldownMs": 3000,
        "fireInitial": false
      }
    },
    {
      "id": "list-flows-command",
      "typeId": "action.listRunnableFlows",
      "position": { "x": 360, "y": 620 },
      "properties": {
        "allowedFlowIds": "{{runnableFlowAllowlist}}",
        "includeHighRisk": true,
        "startNumber": 10,
        "storeMenuInVariable": "runnableFlowsMenu",
        "storeCatalogInVariable": "runnableFlowsCatalog"
      }
    },
    {
      "id": "route-command",
      "typeId": "logic.chatMenuRouter",
      "position": { "x": 640, "y": 620 },
      "properties": {
        "message": "{{watch-message.newText}}",
        "allowedCommands": "{{allowedCommands}}",
        "flowMenuStartNumber": 10,
        "flowCatalogJson": "{{runnableFlowsCatalog}}",
        "storeIntentInVariable": "chatIntent",
        "storeCommandInVariable": "requestedCommand",
        "storeFlowIdInVariable": "requestedFlowId",
        "storeReasonInVariable": "chatRouteReason"
      }
    },
    {
      "id": "capture-screen",
      "typeId": "action.captureScreenshot",
      "position": { "x": 960, "y": 420 },
      "properties": {
        "target": "fullDesktop",
        "outputPath": "",
        "outputFolder": "{{screenshotFolder}}",
        "filenameTemplate": "sidekick_whatsapp_{{timestamp}}",
        "format": "png",
        "quality": 90,
        "delayMs": 250,
        "includeCursor": true
      }
    },
    {
      "id": "compose-screenshot-response",
      "typeId": "logic.textTemplate",
      "position": { "x": 1280, "y": 420 },
      "properties": {
        "template": "Print capturado localmente: {{capture-screen.filePath}}. Envio de midia automatico pelo WhatsApp Web ainda exige revisao local.",
        "storeInVariable": "whatsappResponseMessage"
      }
    },
    {
      "id": "run-command",
      "typeId": "action.consoleCommand",
      "position": { "x": 960, "y": 560 },
      "properties": {
        "shell": "cmd",
        "command": "{{requestedCommand}}",
        "arguments": "",
        "workingDirectory": "",
        "timeoutMs": 15000,
        "captureOutput": true,
        "failOnNonZeroExit": false,
        "storeStdoutInVariable": "commandStdout",
        "storeStderrInVariable": "commandStderr",
        "storeExitCodeInVariable": "commandExitCode"
      }
    },
    {
      "id": "compose-command-response",
      "typeId": "logic.textTemplate",
      "position": { "x": 1280, "y": 560 },
      "properties": {
        "template": "Comando executado: {{requestedCommand}}\\nExit: {{commandExitCode}}\\nSaida:\\n{{commandStdout}}\\nErros:\\n{{commandStderr}}",
        "storeInVariable": "whatsappResponseMessage"
      }
    },
    {
      "id": "system-info",
      "typeId": "action.consoleCommand",
      "position": { "x": 960, "y": 700 },
      "properties": {
        "shell": "powershell",
        "command": "$os = Get-CimInstance Win32_OperatingSystem; $disks = Get-CimInstance Win32_LogicalDisk -Filter 'DriveType=3' | ForEach-Object { '{0}: livre {1:n1}GB de {2:n1}GB' -f $_.DeviceID, ($_.FreeSpace/1GB), ($_.Size/1GB) }; $uptime = (Get-Date) - $os.LastBootUpTime; 'OS: ' + $os.Caption; 'Uptime: ' + [int]$uptime.TotalHours + 'h'; $disks; 'Temperatura: indisponivel sem sensor WMI confiavel'",
        "arguments": "",
        "workingDirectory": "",
        "timeoutMs": 15000,
        "captureOutput": true,
        "failOnNonZeroExit": false,
        "storeStdoutInVariable": "systemInfoText",
        "storeStderrInVariable": "systemInfoError",
        "storeExitCodeInVariable": "systemInfoExitCode"
      }
    },
    {
      "id": "compose-system-response",
      "typeId": "logic.textTemplate",
      "position": { "x": 1280, "y": 700 },
      "properties": {
        "template": "Informacoes do sistema:\\n{{systemInfoText}}\\n{{systemInfoError}}",
        "storeInVariable": "whatsappResponseMessage"
      }
    },
    {
      "id": "compose-list-response",
      "typeId": "logic.textTemplate",
      "position": { "x": 960, "y": 840 },
      "properties": {
        "template": "Flows permitidos agora:\\n{{runnableFlowsMenu}}",
        "storeInVariable": "whatsappResponseMessage"
      }
    },
    {
      "id": "run-selected-flow",
      "typeId": "action.runSavedFlow",
      "position": { "x": 960, "y": 980 },
      "properties": {
        "flowId": "{{requestedFlowId}}",
        "source": "whatsapp",
        "requestedBy": "{{whatsappOwnerPhone}}",
        "allowedFlowIds": "{{runnableFlowAllowlist}}",
        "allowHighRisk": false,
        "storeResultInVariable": "runFlowResult"
      }
    },
    {
      "id": "compose-flow-response",
      "typeId": "logic.textTemplate",
      "position": { "x": 1280, "y": 980 },
      "properties": {
        "template": "Pedido de flow: {{requestedFlowId}}\\nStatus: {{runFlowResult}}",
        "storeInVariable": "whatsappResponseMessage"
      }
    },
    {
      "id": "compose-unknown-response",
      "typeId": "logic.textTemplate",
      "position": { "x": 960, "y": 1120 },
      "properties": {
        "template": "Nao entendi ou o comando foi bloqueado. Motivo: {{chatRouteReason}}\\nEnvie 4 para ver o menu atualizado.",
        "storeInVariable": "whatsappResponseMessage"
      }
    },
    {
      "id": "compose-stop-response",
      "typeId": "logic.textTemplate",
      "position": { "x": 960, "y": 1260 },
      "properties": {
        "template": "Para parar com seguranca, abra o Sidekick e use Stop/Kill Switch. Execucao remota de parada pelo WhatsApp fica bloqueada por politica local.",
        "storeInVariable": "whatsappResponseMessage"
      }
    },
    {
      "id": "type-response",
      "typeId": "action.browserType",
      "position": { "x": 1600, "y": 840 },
      "properties": {
        "windowTitle": "{{whatsappWindowTitle}}",
        "windowTitleMatch": "contains",
        "processName": "{{whatsappProcessName}}",
        "processPath": "{{whatsappProcessPath}}",
        "automationId": "",
        "elementName": "{{whatsappComposerHint}}",
        "elementNameMatch": "contains",
        "controlType": "Edit",
        "text": "{{whatsappResponseMessage}}",
        "clearExisting": false,
        "timeoutMs": 15000
      }
    },
    {
      "id": "send-response",
      "typeId": "action.keyboardPress",
      "position": { "x": 1880, "y": 840 },
      "properties": {
        "key": "Return",
        "modifiers": "None"
      }
    },
    {
      "id": "log-response",
      "typeId": "action.logMessage",
      "position": { "x": 2160, "y": 840 },
      "properties": {
        "message": "WhatsApp Assistant respondeu ao comando {{chatIntent}}.",
        "level": "info"
      }
    },
    {
      "id": "log-composer-not-found",
      "typeId": "action.logMessage",
      "position": { "x": 1880, "y": 1040 },
      "properties": {
        "message": "Nao encontrei o campo de mensagem do WhatsApp. Confira se o chat continua aberto e se o placeholder do composer mudou.",
        "level": "error"
      }
    }
  ],
  "connections": [
    { "id": "c1", "sourceNodeId": "start", "sourcePort": "triggered", "targetNodeId": "focus-existing-whatsapp", "targetPort": "in" },
    { "id": "c2", "sourceNodeId": "focus-existing-whatsapp", "sourcePort": "out", "targetNodeId": "wait-login", "targetPort": "in" },
    { "id": "c3", "sourceNodeId": "focus-existing-whatsapp", "sourcePort": "notFound", "targetNodeId": "open-whatsapp", "targetPort": "in" },
