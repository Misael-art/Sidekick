    { "id": "c10", "sourceNodeId": "type-owner-phone", "sourcePort": "out", "targetNodeId": "delay-search-results", "targetPort": "in" },
    { "id": "c11", "sourceNodeId": "type-owner-phone", "sourcePort": "notFound", "targetNodeId": "log-search-field-not-found", "targetPort": "in" },
    { "id": "c12", "sourceNodeId": "delay-search-results", "sourcePort": "out", "targetNodeId": "select-first-result", "targetPort": "in" },
    { "id": "c13", "sourceNodeId": "select-first-result", "sourcePort": "out", "targetNodeId": "delay-after-result-selection", "targetPort": "in" },
    { "id": "c13b", "sourceNodeId": "delay-after-result-selection", "sourcePort": "out", "targetNodeId": "open-selected-chat", "targetPort": "in" },
