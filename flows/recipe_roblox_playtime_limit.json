{
  "id": "recipe-roblox-playtime-limit",
  "name": "Tempo de Jogo - ROBLOX",
  "version": 1,
  "variables": [
    {
      "name": "tempoPermitidoMs",
      "type": "Integer",
      "default": 120000
    },
    {
      "name": "duracaoAlertaFinalMs",
      "type": "Integer",
      "default": 5000
    },
    {
      "name": "duracaoSilenciosaMs",
      "type": "Integer",
      "default": 115000
    },
    {
      "name": "bloqueioAte",
      "type": "String",
      "default": "00:00"
    },
    {
      "name": "robloxBlockKey",
      "type": "String",
      "default": "roblox-playtime-block"
    },
    {
      "name": "robloxPlayerExePath",
      "type": "String",
      "default": ""
    },
    {
      "name": "robloxLauncherExePath",
      "type": "String",
      "default": ""
    },
    {
      "name": "robloxStudioExePath",
      "type": "String",
      "default": ""
    },
    {
      "name": "gamingServicesUiExePath",
      "type": "String",
      "default": ""
    }
  ],
  "nodes": [
    {
      "id": "watch-player",
      "typeId": "trigger.processEvent",
      "position": { "x": 80, "y": 60 },
      "properties": {
        "eventType": "started",
        "processName": "RobloxPlayerBeta",
        "processPath": "{{robloxPlayerExePath}}",
        "intervalMs": 1000,
        "__ui.alias": "Quando Roblox Player abrir",
        "__ui.comment": "processPath opcional (variavel robloxPlayerExePath): filtra pelo exe real; vazio = so nome. Suporta %LOCALAPPDATA% apos armar. Duplique o gatilho se precisar de outro perfil."
      }
    },
    {
      "id": "watch-launcher",
      "typeId": "trigger.processEvent",
      "position": { "x": 80, "y": 220 },
      "properties": {
        "eventType": "started",
        "processName": "RobloxPlayerLauncher",
        "processPath": "{{robloxLauncherExePath}}",
        "intervalMs": 1000,
        "__ui.alias": "Quando Roblox Launcher abrir",
        "__ui.comment": "processPath opcional via robloxLauncherExePath. vazio = nome apenas."
      }
    },
    {
      "id": "watch-studio",
      "typeId": "trigger.processEvent",
      "position": { "x": 80, "y": 380 },
      "properties": {
        "eventType": "started",
        "processName": "RobloxStudioBeta",
        "processPath": "{{robloxStudioExePath}}",
        "intervalMs": 1000,
        "__ui.alias": "Opcional: Roblox Studio",
        "__ui.comment": "processPath opcional via robloxStudioExePath. Desative o gatilho se Studio nao contar como jogo."
      }
    },
    {
      "id": "cooldown-start",
      "typeId": "logic.cooldown",
      "position": { "x": 380, "y": 220 },
      "properties": {
        "key": "roblox-start-cooldown",
        "cooldownMs": 10000,
        "__ui.alias": "Evitar repeticao rapida",
        "__ui.comment": "Impede loop destrutivo caso varios processos do Roblox subam juntos."
      }
    },
    {
      "id": "read-block",
      "typeId": "action.readState",
      "position": { "x": 680, "y": 220 },
      "properties": {
        "key": "{{robloxBlockKey}}",
        "storeInVariable": "blockValue",
        "__ui.alias": "Verificar bloqueio do dia",
        "__ui.comment": "Resiste a reinicio do Sidekick lendo estado salvo em AppData/Sidekick/state."
      }
    },
    {
      "id": "until-midnight",
      "typeId": "logic.untilDateTime",
      "position": { "x": 980, "y": 90 },
      "properties": {
        "untilLocalTime": "{{bloqueioAte}}",
        "__ui.alias": "Ainda antes da meia-noite?",
        "__ui.comment": "Se o bloqueio ainda vale, fecha de novo e mostra explicacao."
      }
    },
    {
      "id": "overlay-blocked",
      "typeId": "action.overlayText",
      "position": { "x": 1280, "y": 60 },
      "properties": {
        "text": "Roblox esta bloqueado ate 00:00. Amanhã libera de novo.",
        "fontSize": 46,
        "textColor": "#FFFFFF",
        "backgroundColor": "#5B2333",
        "durationMs": 4500,
        "fullScreen": true,
        "plane": "foreground",
        "motion": "slideRight",
        "__ui.alias": "Mensagem de bloqueio",
        "__ui.comment": "Feedback claro quando a crianca tenta abrir novamente no mesmo dia."
      }
    },
    {
      "id": "play-blocked",
      "typeId": "action.playSound",
      "position": { "x": 1580, "y": 60 },
      "properties": {
        "soundFile": "",
        "systemSound": "hand",
        "__ui.alias": "Som de bloqueio",
        "__ui.comment": "Usa som do Windows por padrao, sem depender de arquivo externo."
      }
    },
    {
      "id": "kill-blocked-player",
      "typeId": "action.killProcess",
      "position": { "x": 1880, "y": 60 },
      "properties": {
        "processName": "RobloxPlayerBeta",
        "__ui.alias": "Fechar Roblox bloqueado",
        "__ui.comment": "Fecha o processo principal quando o bloqueio do dia ainda esta ativo."
      }
    },
    {
      "id": "overlay-start",
      "typeId": "action.overlayText",
      "position": { "x": 980, "y": 320 },
      "properties": {
        "text": "Tempo iniciado: silencioso {{duracaoSilenciosaMs}} ms + alerta {{duracaoAlertaFinalMs}} ms (total {{tempoPermitidoMs}} ms).",
        "fontSize": 48,
        "textColor": "#FFFFFF",
        "backgroundColor": "#163B45",
        "durationMs": 4000,
        "fullScreen": true,
        "plane": "foreground",
        "motion": "slideUp",
        "__ui.alias": "Aviso inicial amigavel",
        "__ui.comment": "Personalize texto e variaveis de tempo antes de armar."
      }
    },
    {
      "id": "timer-main",
      "typeId": "logic.delay",
      "position": { "x": 1280, "y": 320 },
      "properties": {
        "milliseconds": "{{duracaoSilenciosaMs}}",
        "__ui.alias": "Timer principal (silencioso)",
        "__ui.comment": "Usa variavel duracaoSilenciosaMs (tipicamente tempoPermitidoMs - duracaoAlertaFinalMs). Suporta {{variaveis}} no Delay."
      }
    },
    {
      "id": "overlay-warning",
      "typeId": "action.overlayText",
      "position": { "x": 1580, "y": 320 },
      "properties": {
        "text": "Faltam {{duracaoAlertaFinalMs}} ms!",
        "fontSize": 72,
        "textColor": "#FFFFFF",
        "backgroundColor": "#7C2D12",
        "durationMs": "{{duracaoAlertaFinalMs}}",
        "fullScreen": true,
        "plane": "foreground",
        "motion": "slideRight",
        "effect": "outline",
        "__ui.alias": "Alerta final piscante",
        "__ui.comment": "durationMs e texto usam duracaoAlertaFinalMs; altere a variavel no flow para mudar alerta e overlay juntos."
      }
    },
    {
      "id": "play-warning",
      "typeId": "action.playSound",
      "position": { "x": 1880, "y": 320 },
      "properties": {
        "soundFile": "",
        "systemSound": "exclamation",
        "__ui.alias": "Som dos ultimos segundos",
        "__ui.comment": "Toca alerta nos ultimos segundos usando som do Windows."
      }
    },
    {
      "id": "close-window",
      "typeId": "action.windowControl",
      "position": { "x": 2180, "y": 320 },
      "properties": {
        "windowTitle": "Roblox",
        "windowTitleMatch": "contains",
        "processName": "RobloxPlayerBeta",
        "processPath": "{{robloxPlayerExePath}}",
        "controlType": "Window",
        "timeoutMs": 3500,
        "operation": "close",
        "__ui.alias": "Fechar janela do RobloxPlayerBeta",
        "__ui.comment": "WM_CLOSE: titulo Roblox + processo RobloxPlayerBeta. processPath opcional (robloxPlayerExePath) restringe ao exe; vazio = so processo+titulo. timeoutMs 3500 ms. Se notFound, tenta GamingServicesUI."
      }
    },
    {
      "id": "close-gaming-host",
      "typeId": "action.windowControl",
      "position": { "x": 2330, "y": 320 },
      "properties": {
        "windowTitle": "Roblox",
        "windowTitleMatch": "contains",
        "processName": "GamingServicesUI",
        "processPath": "{{gamingServicesUiExePath}}",
        "controlType": "Window",
        "timeoutMs": 4000,
        "operation": "close",
        "__ui.alias": "Fechar hospedeiro Gaming Services (fallback)",
        "__ui.comment": "Fallback: titulo Roblox + GamingServicesUI. gamingServicesUiExePath opcional (caminho em WindowsApps muda entre versoes — prefira vazio ou variavel preenchida na sua maquina)."
      }
    },
    {
      "id": "kill-player",
      "typeId": "action.killProcess",
      "position": { "x": 2630, "y": 320 },
      "properties": {
        "processName": "RobloxPlayerBeta",
        "__ui.alias": "Forcar fechamento se preciso",
        "__ui.comment": "Fallback final: encerra RobloxPlayerBeta apos tentativas de fechamento gracioso."
      }
    },
    {
      "id": "persist-block",
      "typeId": "action.persistState",
      "position": { "x": 2960, "y": 320 },
      "properties": {
        "key": "{{robloxBlockKey}}",
        "value": "blocked",
        "expiresAtLocal": "{{bloqueioAte}}",
        "__ui.alias": "Bloquear ate 00:00",
        "__ui.comment": "Persistencia local protege contra reinicio do Sidekick."
      }
    },
    {
      "id": "overlay-ended",
      "typeId": "action.overlayText",
      "position": { "x": 3260, "y": 320 },
      "properties": {
        "text": "Seu tempo acabou!",
        "fontSize": 92,
        "textColor": "#FFFFFF",
        "backgroundColor": "#111827",
        "durationMs": 7000,
        "fullScreen": true,
        "plane": "foreground",
        "motion": "slideRight",
        "effect": "outline",
        "__ui.alias": "Mensagem final grande",
        "__ui.comment": "Atravessa a tela da esquerda para a direita."
      }
    },
    {
      "id": "play-ended",
      "typeId": "action.playSound",
      "position": { "x": 3560, "y": 320 },
      "properties": {
        "soundFile": "",
        "systemSound": "question",
        "__ui.alias": "Som final",
        "__ui.comment": "Som distinto de bloqueio (hand) e alerta (exclamation): question marca o encerramento. Alternativas: asterisk, beep."
      }
    }
  ],
  "connections": [
    { "id": "c-watch-player-cooldown", "sourceNodeId": "watch-player", "sourcePort": "triggered", "targetNodeId": "cooldown-start", "targetPort": "in" },
    { "id": "c-watch-launcher-cooldown", "sourceNodeId": "watch-launcher", "sourcePort": "triggered", "targetNodeId": "cooldown-start", "targetPort": "in" },
    { "id": "c-watch-studio-cooldown", "sourceNodeId": "watch-studio", "sourcePort": "triggered", "targetNodeId": "cooldown-start", "targetPort": "in" },
    { "id": "c-cooldown-read", "sourceNodeId": "cooldown-start", "sourcePort": "passthrough", "targetNodeId": "read-block", "targetPort": "in" },
    { "id": "c-read-found-until", "sourceNodeId": "read-block", "sourcePort": "found", "targetNodeId": "until-midnight", "targetPort": "in" },
    { "id": "c-until-before-overlay", "sourceNodeId": "until-midnight", "sourcePort": "before", "targetNodeId": "overlay-blocked", "targetPort": "in" },
    { "id": "c-overlay-blocked-sound", "sourceNodeId": "overlay-blocked", "sourcePort": "out", "targetNodeId": "play-blocked", "targetPort": "in" },
    { "id": "c-sound-blocked-kill", "sourceNodeId": "play-blocked", "sourcePort": "out", "targetNodeId": "kill-blocked-player", "targetPort": "in" },
    { "id": "c-read-missing-start", "sourceNodeId": "read-block", "sourcePort": "missing", "targetNodeId": "overlay-start", "targetPort": "in" },
    { "id": "c-until-after-start", "sourceNodeId": "until-midnight", "sourcePort": "after", "targetNodeId": "overlay-start", "targetPort": "in" },
    { "id": "c-start-timer", "sourceNodeId": "overlay-start", "sourcePort": "out", "targetNodeId": "timer-main", "targetPort": "in" },
    { "id": "c-timer-warning", "sourceNodeId": "timer-main", "sourcePort": "out", "targetNodeId": "overlay-warning", "targetPort": "in" },
    { "id": "c-warning-sound", "sourceNodeId": "overlay-warning", "sourcePort": "out", "targetNodeId": "play-warning", "targetPort": "in" },
    { "id": "c-warning-close", "sourceNodeId": "play-warning", "sourcePort": "out", "targetNodeId": "close-window", "targetPort": "in" },
    { "id": "c-close-kill", "sourceNodeId": "close-window", "sourcePort": "out", "targetNodeId": "kill-player", "targetPort": "in" },
    { "id": "c-close-notfound-gaming", "sourceNodeId": "close-window", "sourcePort": "notFound", "targetNodeId": "close-gaming-host", "targetPort": "in" },
    { "id": "c-gaming-kill", "sourceNodeId": "close-gaming-host", "sourcePort": "out", "targetNodeId": "kill-player", "targetPort": "in" },
    { "id": "c-gaming-notfound-kill", "sourceNodeId": "close-gaming-host", "sourcePort": "notFound", "targetNodeId": "kill-player", "targetPort": "in" },
    { "id": "c-kill-persist", "sourceNodeId": "kill-player", "sourcePort": "out", "targetNodeId": "persist-block", "targetPort": "in" },
    { "id": "c-persist-ended", "sourceNodeId": "persist-block", "sourcePort": "out", "targetNodeId": "overlay-ended", "targetPort": "in" },
    { "id": "c-ended-sound", "sourceNodeId": "overlay-ended", "sourcePort": "out", "targetNodeId": "play-ended", "targetPort": "in" }
  ],
  "annotations": [
    {
      "id": "sticky-overview",
      "title": "Como usar",
      "body": "1) Arme apos revisar variaveis. 2) tempoPermitidoMs = duracaoSilenciosaMs + duracaoAlertaFinalMs (ex. 120000 = 115000 + 5000). 3) Caminhos exe opcionais (robloxPlayerExePath, etc.): vazio = filtro so por nome; preencha com exe real se tiver colisao. Use %LOCALAPPDATA%\\Roblox\\Versions\\...\\RobloxPlayerBeta.exe como exemplo — nao commite caminho fixo de WindowsApps. 4) Ao armar, gatilhos resolvem {{variaveis}} dos defaults do flow. 5) Tres gatilhos de processo; Studio opcional.",
      "color": "yellow",
      "position": { "x": 620, "y": -200 },
      "width": 480,
      "height": 220
    },
    {
      "id": "sticky-mira-inspector",
      "title": "Mira / Inspector (exemplo real)",
      "body": "No Inspector pode aparecer: titulo com segmentos Window • Roblox • Roblox • media • relativePositionFallback; processo gamingservicesui (PID exemplo 21660); exe em WindowsApps\\Microsoft.GamingServices_*\\GamingServicesUI.exe (versao muda); bounds exemplo 1296x729; classe GAMINGSERVICESUI_HOSTING_WINDOW_CLASS. Isso explica o segundo Window Control: fechar pela janela com titulo Roblox mas processo GamingServicesUI. Media/relative/fallback na Mira ensinam captura resiliente — aqui usamos UIA + fallback de processo.",
      "color": "blue",
      "position": { "x": 2060, "y": 520 },
      "width": 420,
      "height": 260
    },
    {
      "id": "sticky-close-vs-kill",
      "title": "Por que WM_CLOSE antes do Kill?",
      "body": "Fechar com Window Control envia WM_CLOSE (encerramento gracioso). Kill Process encerra o executavel: use depois das tentativas de janela para garantir que o Roblox pare mesmo se o seletor nao achar o HWND ou o usuario travar o dialogo.",
      "color": "green",
      "position": { "x": 2180, "y": -120 },
      "width": 380,
      "height": 160
    },
    {
      "id": "sticky-timing",
      "title": "Temporizacao do fluxo",
      "body": "Overlay inicial (~4s) -> Delay com {{duracaoSilenciosaMs}} -> overlay de alerta (texto + durationMs ligados a duracaoAlertaFinalMs) -> sons e fechamentos -> persistState ate bloqueioAte -> overlay final. O bloqueio do dia reutiliza readState/untilDateTime na entrada.",
      "color": "yellow",
      "position": { "x": 1180, "y": 520 },
      "width": 400,
      "height": 200
    },
    {
      "id": "sticky-exe-paths",
      "title": "Caminhos exe opcionais",
      "body": "robloxPlayerExePath / robloxLauncherExePath / robloxStudioExePath / gamingServicesUiExePath: deixe vazio para o fluxo usar so o nome do processo (portavel). Preencha se precisar distinguir exes homonimos. Exemplo tipico do player: %LOCALAPPDATA%\\Roblox\\Versions\\<pasta>\\RobloxPlayerBeta.exe — a pasta hash muda quando o Roblox atualiza. Gaming Services em WindowsApps muda de versao; use variavel local, nao fixe no repositorio.",
      "color": "purple",
      "position": { "x": 40, "y": 520 },
      "width": 440,
      "height": 220
    },
    {
      "id": "sticky-sounds",
      "title": "Sons (Play Sound)",
      "body": "soundFile vazio = so systemSound. Valores: exclamation, asterisk, beep, hand, question. Receita: hand / exclamation / question. WAV opcional: %WINDIR%\\Media\\Windows Notify.wav",
      "color": "pink",
      "position": { "x": 3180, "y": -120 },
      "width": 420,
      "height": 200
    }
  ],
  "createdAt": "2026-05-02T00:00:00Z",
  "modifiedAt": "2026-05-05T00:00:00Z"
}
